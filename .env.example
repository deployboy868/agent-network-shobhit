# Copy this file to `.env` and fill in values your mentor provides.
# Never commit `.env` to git.

# --- Mode ---
# mock = use in-memory fake tools (default for first 4 weeks)
# live = call real APIs (only after mentor gives credentials)
AGENT_NETWORK_MODE=mock

# --- Jira (when live) ---
# Use the SAME email you used when creating the API token (Atlassian account email).
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=paste_token_here
# Sandbox project key from mentor (e.g. INTERN, SANDBOX)
JIRA_PROJECT_KEY=
# Issue type name in that project (often Task, Story, Bug)
JIRA_ISSUE_TYPE=Task
# Prefix on NEW tickets only; assign/close blocked without this prefix (protects old issues)
JIRA_SAFE_PREFIX=[Agent-Network-TEST]
# true = assign tickets to JIRA_EMAIL (you) only in live demos (recommended)
JIRA_DEMO_SAFE_MODE=true
# Final close button from In Review (LST project uses exactly CLOSED)
JIRA_DONE_TRANSITION=CLOSED
# LST: auto-walks forward Need Review -> In Progress -> In Review -> Closed
# Set to "enabled" or any value; optional hints: Start Progress,Send for Review,Close
JIRA_CLOSE_WORKFLOW=enabled

# --- GitLab (when live) ---
GITLAB_BASE_URL=https://gitlab.com
GITLAB_PRIVATE_TOKEN=
# Run: python -m agent_network.demo.discover_gitlab_projects  (or ask mentor)
GITLAB_PROJECT_ID=

# Default branch (main or master). Leave blank to auto-detect from GitLab API.
GITLAB_DEFAULT_BRANCH=main

# --- Microsoft Teams (when live) ---
# Usually Azure AD app registration + Graph API
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# --- Workday (when live) ---
# Highly org-specific; ask mentor for sandbox + API docs
WORKDAY_BASE_URL=
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=

# --- LLM provider selection ---
# Auto-detect order: ollama (if OLLAMA_ENABLED) > groq (if GROQ_API_KEY) > grok > openai.
# Or force with LLM_PROVIDER=groq|grok|ollama|openai|none
LLM_PROVIDER=

# Ollama (local dev — not reachable from a cloud host)
OLLAMA_ENABLED=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Groq (cloud — fast inference, OpenAI-compatible API)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Grok / x.ai (cloud — alternative)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# OpenAI / Azure (alternative cloud)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Conversation memory ---
TWIN_MEMORY_DB=.twin-memory.db
TWIN_MEMORY_TURNS=10

# --- Microsoft Teams bot (Bot Framework / Azure Bot) ---
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
# Local Emulator without Azure: leave id/password blank (or BOT_EMULATOR_MODE=true)
BOT_EMULATOR_MODE=true
# Demo mode: one Teams user can impersonate roster roles via chat (act as demo assignee)
TEAMS_DEMO_MODE=true
# Emulator identity when TEAMS_USER_MAP cannot resolve the user
DEFAULT_REQUESTER_ID=emp-manager
DEFAULT_TWIN_ID=emp-manager
# Real Teams: map sign-in email → roster id, e.g. {"you@company.com":"emp-manager"}
TEAMS_USER_MAP=

# --- Microsoft Graph (Teams presence: Presence.Read.All + admin consent) ---
TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# --- Agent-to-agent peers (real cross-service A2A) ---
# {"twin-emp-assignee":"http://host:8766"}
A2A_PEERS=
